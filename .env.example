# =================================
# ORBIT Configuration
# =================================

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgres://orbit:orbit@localhost:5432/orbit_dev

# ORBIT Core
ORBIT_SECRET_KEY=replace-with-random-secret-for-watermark
ORBIT_PLATFORM_ID=ohnrshyp

# Logging
LOG_LEVEL=debug

# =================================
# ML Model Configuration (Session 18+)
# =================================
# All optional - defaults are sensible for development

# Where to cache downloaded models (~1.3GB total for all models)
# ORBIT_MODEL_CACHE_DIR=./models

# Device preference: 'auto', 'gpu', or 'cpu'
# ORBIT_ML_DEVICE=auto

# Enable verbose logging during model download (true in development by default)
# ORBIT_ML_VERBOSE=true

# Model download timeout in milliseconds (default: 5 minutes)
# ORBIT_MODEL_DOWNLOAD_TIMEOUT=300000

# =================================
# External Catalog Services
# =================================

# AcoustID (free, ~30M fingerprints) — optional but recommended
# ACOUSTID_API_KEY=your_acoustid_key

# ACRCloud (commercial, ~100M+ tracks) — optional, adds paid catalog check
# Sign up at https://www.acrcloud.com/ to get project credentials
# ACRCLOUD_ACCESS_KEY=your_access_key
# ACRCLOUD_SECRET_KEY=your_access_secret
# ACRCLOUD_HOST=identify-us-west-2.acrcloud.com

# =================================
# AI Detection Rollout Flags (all default-off safety)
# =================================
# Enable v2 scoring/recommendation path (legacy remains default when false)
ORBIT_AI_V2_ENABLED=false
# Compute v2 in parallel but return legacy recommendation
ORBIT_AI_SHADOW_MODE=false
# Run audio analysis in register flow and pass to AI detector
ORBIT_AI_REGISTER_ANALYSIS_ENABLED=false
# Enable CLAP KNN reference-distance signal
ORBIT_AI_KNN_ENABLED=false
# Enable v2 semantic prompt set for detector probing
ORBIT_AI_PROMPTS_V2_ENABLED=false
# Enable expanded metadata intelligence checks
ORBIT_AI_METADATA_V2_ENABLED=false
# Enable cross-signal weighting and mismatch checks
ORBIT_AI_CROSSSIGNAL_V2_ENABLED=false
# Enable v3 forensics (pre-echo, HF phase, M/S coherence, pitch jitter, watermark detection)
ORBIT_AI_FORENSICS_V3_ENABLED=false
