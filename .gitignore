# Dependencies
node_modules/

# Environment files
.env
.env.local
*.local

# Platform credentials (generated by seed-platform.js)
.*-credentials.json

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.cursor/
.vscode/
.idea/

# Build output
dist/
build/

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp
.cache/

# Model cache (can be large)
models/
.test-model-cache/

# Audio test files (can be large)
*.wav
*.mp3
*.flac
# Note: test audio files in tests/fixtures/ are also ignored (too large for git)
# Python virtual environments
.venv/
.venv-watermark/

# Benchmarks (results, scripts, handoff docs — may contain credentials)
benchmarks/
benchmarks.md
BENCHMARK_HANDOFF.md

# Python bytecode
__pycache__/
*.pyc

# Marketing / internal docs (not for repo)
docs/LINKEDIN_CONTENT_CALENDAR.md

# Generated test output
tests/corpus-results.json
