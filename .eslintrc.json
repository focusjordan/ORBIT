{
  "env": {
    "node": true,
    "es2022": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off"
  },
  "ignorePatterns": [
    "node_modules/",
    ".venv/",
    ".venv-watermark/",
    "panns_data/",
    "dist/",
    "temp/",
    "models/",
    ".test-model-cache/"
  ]
}
