{
  "name": "orbit",
  "version": "1.0.0",
  "description": "Origin-Based Identity & Rights Transfer Protocol - Audio provenance and metadata transfer system",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "node scripts/migrate.js",
    "test": "node tests/integration/full-flow.test.js",
    "test:integration": "node tests/integration/full-flow.test.js",
    "test:fresh": "node scripts/test-setup.js && node tests/integration/full-flow.test.js",
    "test:setup": "node scripts/test-setup.js",
    "test:clean": "node scripts/test-setup.js --clean",
    "test:all": "node scripts/run-tests.js all",
    "test:all:fast": "node scripts/run-tests.js all --fast",
    "test:all:full": "node scripts/run-tests.js all --full",
    "test:unit": "node scripts/run-tests.js unit",
    "test:v1": "node scripts/run-tests.js v1 --fast",
    "test:v2:safe": "node scripts/run-tests.js v2:safe",
    "test:fingerprint": "node tests/engines/fingerprint.test.js",
    "test:fingerprint:db": "node tests/engines/fingerprint-db.test.js",
    "test:crypto": "node tests/engines/crypto.test.js",
    "test:watermark:embed": "node tests/engines/watermark-embed.test.js",
    "test:watermark:extract": "node tests/engines/watermark-extract.test.js",
    "test:watermark:unified": "node tests/engines/watermark-unified.test.js",
    "test:watermark": "npm run test:watermark:embed && npm run test:watermark:extract && npm run test:watermark:unified",
    "test:audio": "node tests/utils/audio.test.js",
    "test:auth": "node tests/api/auth.test.js",
    "test:register": "node tests/api/register.test.js",
    "test:register:full": "node tests/api/register-full-metadata.test.js",
    "test:verify": "node tests/api/verify.test.js",
    "test:chain": "node tests/api/chain.test.js",
    "test:v2": "node tests/api/v2-endpoints.test.js",
    "test:sdk": "node sdk/test.js",
    "test:models": "node tests/ml/models.test.js",
    "test:mert": "node tests/ml/mert.test.js",
    "test:clap": "node tests/ml/clap.test.js",
    "test:audio-analysis": "node tests/ml/audio-analysis.test.js",
    "test:metadata-extractor": "node tests/ml/metadata-extractor.test.js",
    "test:silentcipher": "node tests/ml/silentcipher.test.js",
    "test:content-analysis": "node tests/ml/content-analysis.test.js",
    "test:ml": "npm run test:models && npm run test:mert && npm run test:clap && npm run test:audio-analysis && npm run test:metadata-extractor && npm run test:silentcipher && npm run test:content-analysis",
    "generate:keypair": "node scripts/generate-keypair.js",
    "seed:platform": "node scripts/seed-platform.js"
  },
  "keywords": [
    "audio",
    "watermark",
    "fingerprint",
    "provenance",
    "metadata",
    "music",
    "b2b"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "cbor": "^10.0.11",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "tweetnacl": "^1.0.3",
    "wav-decoder": "^1.3.0",
    "wav-encoder": "^1.3.0"
  },
  "devDependencies": {
    "form-data": "^4.0.5",
    "nodemon": "^3.1.11"
  }
}
